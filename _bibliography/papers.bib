@article{Padilla-Gay:2020uxa,
    abbr = {JCAP},
    author = {Padilla-Gay, Ian and Shalgar, Shashank and Tamborra, Irene},
    title = {Multi-Dimensional Solution of Fast Neutrino Conversions in Binary Neutron Star Merger Remnants},
    abstract = {
                Fast pairwise conversions of neutrinos are predicted to be ubiquitous in neutron star merger remnants, with potentially major implications for the nucleosynthesis of elements heavier than iron. We present the first sophisticated numerical solution of the neutrino flavor evolution above the remnant disk within a (2+1+1)-dimensional setup: two spatial coordinates, one angular variable, and time. We search for a steady-state flavor configuration above the remnant disk.
                Although linear stability analysis predicts flavor instabilities at all locations above the remnant disk, our nonlinear simulations show that fast pairwise conversions lead to minimal neutrino mixing (less than 1%); flavor equilibration is never achieved in our models. Importantly, fast neutrino conversions are more prominent in localized regions near the edges of the (anti)neutrino decoupling surfaces and are almost negligible in the polar region of the remnant.
                Our findings on the role of fast pairwise conversions should be interpreted with caution because of the approximations inherent in our setup, and they motivate further studies within a more realistic framework.

    },
    arxiv = {2009.01843},
    doi = {10.1088/1475-7516/2021/01/017},
    journal = {JCAP},
    url = {https://doi.org/10.1088/1475-7516/2021/01/017},
    volume = {01},
