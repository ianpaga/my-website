@article{Friedland:2025lge,
    abbr = {JCAP},
    author = {Friedland, Alexander and Li, Derek J. and Lucente, Giuseppe and \textbf{Padilla-Gay, Ian} and Patwardhan, Amol V.},
    title = {vp-process in core-collapse supernovae: imprints of general relativistic effects},
    abstract = {
                The origin of a number of proton-rich isotopes in the solar system has been a long-standing puzzle. A promising explanation is the νp-process, which is thought to occur in neutrino-driven outflows that form inside core-collapse supernovae after shock revival. While recent studies have analyzed several physical effects that influence the efficiency of this process, the impact of General Relativity (GR) has not yet been explored.
                Here we perform a comparative analysis of the time-integrated νp-process yields in Newtonian and fully GR calculations, using detailed models of time-evolving outflow profiles. GR effects are found to suppress the production of seed nuclei, which significantly boosts the resulting p-nuclide abundances.
                Our reference GR model, with an 18 M⊙ progenitor, reproduces both the relative and absolute solar-system abundances of the full set of p-nuclides in the mass range 74 ≤ A ≤ 102. The yields are less optimal in our 12.75 M⊙ GR model, where the outflow transitions to the supersonic regime several seconds into the explosion, suppressing further p-nuclide production.
                In both models, most of the production of the key p-isotopes 92,94Mo and 96,98Ru occurs relatively early, about 1–3 seconds after shock revival. In contrast, a large fraction of the shielded isotope 92Nb is produced in the later ejecta. The impact of GR on this isotope is particularly strong, with its final abundance increased by a factor of 25 compared to a Newtonian calculation.
                In summary, when GR effects are included, the νp-process in a sufficiently massive progenitor can provide a unified explanation for the origin of all p-nuclei in the solar system up to 102Pd.
                },
    arxiv = {2508.02055},
    doi = {10.1088/1475-7516/2026/02/067},
    journal = {JCAP},
    doi = {10.1088/1475-7516/2026/02/067},
    url = {https://iopscience.iop.org/article/10.1088/1475-7516/2026/02/067},
    volume = {02},
    pages = {067},
    year = {2026},
    selected = {true},
    bibtex_show = {true},
    inspirehep_id = {2957161},
    dimensions = {true},
    preview={nup.png}
}

@article{Padilla-Gay:2025tko,
    abbr = {Phys. Rev. D},
    author = {Padilla-Gay, Ian and Chen, Heng-Hao and Abbar, Sajad and Wu, Meng-Ru and Xiong, Zewei},
    title = {Flavor equilibration of supernova neutrinos: Exploring the dynamics of slow modes},
    abstract = {
                Neutrinos experience collective flavor conversion in extreme astrophysical environments such as core-collapse supernovae (CCSNe). One manifestation of collective conversion is slow flavor conversion (SFC), which has recently attracted renewed interest because of its ubiquity across different regions of the supernova environment. In this study, we systematically examine the evolution of kinematic decoherence in a dense neutrino gas undergoing SFC, considering lepton number asymmetries as large as 30%.
                Our findings show that the neutrino gas asymptotically evolves toward a generic state of coarse-grained flavor equilibration that is constrained by approximate lepton number conservation. The equilibration occurs within a few factors of the inverse vacuum oscillation frequency, ω⁻¹, corresponding to (anti)neutrinos reaching near flavor equipartition after traveling only a few kilometers for typical supernova neutrino energies.
                Notably, the quasi-steady state of the neutrino number densities can be quantitatively described by the neutrino–antineutrino number density ratio n_{\barν_e} / n_{ν_e} alone. Such a simple estimate opens new opportunities for incorporating SFC into CCSN simulations, particularly in regions where SFC develops on scales much shorter than those of collisions.
    },
    arxiv = {2505.11588},
    doi = {10.1103/jg14-8p4l},
    journal = {Phys. Rev. D},
    url = {https://doi.org/10.1103/jg14-8p4l},
    volume = {112},
    number = {4},
    pages = {043039},
    year = {2025},
    selected = {true},
    bibtex_show = {true},
    inspirehep_id = {2922473},
    dimensions = {true},
    preview = {equilib.png}
}

@article{Padilla-Gay:2024wyo,
    abbr = {JCAP},
    author = {Padilla-Gay, Ian and Shalgar, Shashank and Tamborra, Irene},
    title = {Symmetry breaking due to multi-angle matter-neutrino resonance in neutron star merger remnants},
    abstract = {
                Neutron star merger remnants are unique sites for exploring neutrino flavor conversion in dense media. Because of the natural excess of antielectron neutrinos over electron neutrinos, the neutrino–neutrino potential can cancel the matter potential, giving rise to matter–neutrino resonant flavor conversion. Under the assumption of two (anti)neutrino flavors and spatial homogeneity, we solve the neutrino quantum kinetic equations to investigate the occurrence of the matter–neutrino resonance within a multi-angle framework.
                We find that isotropy is broken spontaneously, regardless of the mass ordering. Using a hydrodynamical simulation of a binary neutron star merger remnant with a black hole of 3 solar masses and an accretion torus of 0.3 solar masses, we find that complete flavor conversion caused by the matter–neutrino resonance is unlikely, even though the matter and neutrino potentials cancel at various locations above the disk.
                Importantly, matter–neutrino resonant flavor conversion depends crucially on the shape of the neutrino angular distributions. Our findings suggest that accurate modeling of the neutrino angular distributions is necessary to understand flavor conversion physics in merger remnants, as well as its implications for disk physics and the synthesis of elements heavier than iron.
    },
    arxiv = {2403.15532},
    doi = {10.1088/1475-7516/2024/05/037},
    journal = {JCAP},
    url = {https://doi.org/10.1088/1475-7516/2024/05/037},
    volume = {05},
    pages = {037},
    year = {2024},
    selected = {true},
    bibtex_show = {true},
    inspirehep_id = {2771383},
    dimensions = {true},
    preview = {mnr.png}
}

@article{Fiorillo:2023ajs,
    abbr = {Phys. Rev. D},
    author = {Fiorillo, Damiano F. G. and Padilla-Gay, Ian and Raffelt, Georg G.},
    title = {Collisions and collective flavor conversion: Integrating out the fast dynamics},
    abstract = {
                In dense astrophysical environments, notably core-collapse supernovae and neutron star mergers, neutrino–neutrino forward scattering can trigger flavor conversion on very short scales. Scattering with the background medium can influence collective flavor conversion in several ways, either damping oscillations or potentially triggering new collisional flavor instabilities (CFIs). A key aspect of this process is the relative slowness of collisions compared to the much faster dynamics of neutrino–neutrino refraction.
                Assuming spatial homogeneity, we exploit this hierarchy of scales to simplify the description by accounting only for the slow dynamics driven by collisions. We illustrate our approach both for CFIs and for fast flavor instabilities that are damped by collisions. In both cases, our method leads to a new set of equations, the slow-dynamics equations, which simplify the description of flavor conversion and allow a qualitative understanding of the final state of the system once the instability—either collisional or fast—has saturated.
    },
    arxiv = {2312.07612},
    doi = {10.1103/PhysRevD.109.063021},
    journal = {Phys. Rev. D},
    url = {https://doi.org/10.1103/PhysRevD.109.063021},
